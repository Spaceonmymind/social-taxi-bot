# =============================================================================
# СОЦИАЛЬНОЕ ТАКСИ — ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
# =============================================================================
# Скопируйте этот файл: cp .env.example .env
# Заполните .env своими значениями.
# ВАЖНО: файл .env содержит секреты — никому не передавайте и не публикуйте.
# =============================================================================


# -----------------------------------------------------------------------------
# ОБЯЗАТЕЛЬНЫЕ ПОЛЯ — без них бот не запустится
# -----------------------------------------------------------------------------

# Токен бота MAX.
# Как получить:
#   1. Откройте мессенджер MAX
#   2. Найдите бота @MaxDevBot и напишите /start
#   3. Выберите «Создать бота», придумайте имя и username
#   4. Скопируйте полученный токен
BOT_TOKEN=ваш_токен_бота

# URL опубликованного мини-приложения (файл miniapp/index.html).
# Обязательно HTTPS — MAX не открывает мини-приложения по HTTP.
# Примеры:
#   GitHub Pages: https://username.github.io/social-taxi/index.html
#   Vercel:       https://social-taxi.vercel.app/index.html
#   Свой сервер:  https://taxi.example.ru/miniapp/index.html
MINI_APP_URL=https://your-domain.ru/miniapp/index.html

# Числовые ID операторов через запятую (без пробелов).
# Операторы — это люди, которые будут получать заявки и управлять ими в боте.
# Как узнать свой ID:
#   Напишите любое сообщение боту @getmyid_bot в мессенджере MAX —
#   он ответит вашим числовым ID (например: 123456789).
# Пример для одного оператора:  ADMIN_IDS=123456789
# Пример для двух операторов:   ADMIN_IDS=123456789,987654321
ADMIN_IDS=123456789

# Секретный токен для защиты admin-эндпоинтов HTTP-сервера.
# Придумайте сами — любая случайная строка из букв и цифр (минимум 16 символов).
# Пример: Kx9mP2qL8nR5vT3w
# Этот токен используется в заголовке X-Admin-Token при запросах к /api/admin/*
ADMIN_TOKEN=your_secret_admin_token_here

# Секрет для проверки входящих Webhook-запросов MAX.
# Укажите это же значение в поле secret при создании подписки POST /subscriptions.
# Допустимы латинские буквы, цифры, дефис и подчёркивание; длина 5–256 символов.
WEBHOOK_SECRET=your_webhook_secret_here


# -----------------------------------------------------------------------------
# НЕОБЯЗАТЕЛЬНЫЕ ПОЛЯ — есть значения по умолчанию, менять не обязательно
# -----------------------------------------------------------------------------

# Порт HTTP-сервера (server.js), который принимает заявки из мини-приложения.
# По умолчанию: 3000
# Если на сервере порт 3000 уже занят другим приложением — измените на другой.
PORT=3000

# Путь к файлу базы заявок. Файл создаётся автоматически при первой заявке.
# По умолчанию: ./requests.json
DB_FILE=./requests.json

# Путь к файлу базы отзывов. Файл создаётся автоматически при первом отзыве.
# По умолчанию: ./feedback.json
FEEDBACK_FILE=./feedback.json
